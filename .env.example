# ─── Application ──────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────
DB_NAME=tm_scheduler
DB_USER=tm_user
DB_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql://tm_user:changeme_strong_password@localhost:5432/tm_scheduler

# ─── JWT ──────────────────────────────────────
# Must be >= 32 random characters in production
JWT_SECRET=changeme_generate_a_long_random_secret_here
JWT_EXPIRES_IN=7d

# ─── Admin credentials ────────────────────────
ADMIN_USERNAME=admin
# Generate with: node -e "require('bcrypt').hash('yourpassword',10).then(console.log)"
# IMPORTANT: In the .env file, escape every '$' in the hash as '$$'
# Example real value in .env:  ADMIN_PASSWORD_HASH=$$2b$$10$$actualHashCharsHere
ADMIN_PASSWORD_HASH=$$2b$$10$$replace_this_with_a_real_bcrypt_hash

# ─── CORS ─────────────────────────────────────
CORS_ORIGIN=http://localhost

# ─── Frontend ─────────────────────────────────
VITE_API_BASE_URL=/api/v1

# TM Scheduler — Release docker-compose.yml
#
# THIS FILE IS GENERATED BY THE RELEASE WORKFLOW — DO NOT HAND-EDIT.
# Template: docker/docker-compose.release.tmpl
# Placeholders replaced at build time:
#   BACKEND_IMAGE_PLACEHOLDER  → tm-scheduler-backend:<version>
#   FRONTEND_IMAGE_PLACEHOLDER → tm-scheduler-frontend:<version>
# ─────────────────────────────────────────────────────────────────────────────

name: tm-scheduler

services:

  # ── PostgreSQL ──────────────────────────────────────────────────────────────
  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      POSTGRES_DB:       ${DB_NAME:-tm_scheduler}
      POSTGRES_USER:     ${DB_USER:-tm_user}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER:-tm_user} -d ${DB_NAME:-tm_scheduler}"]
      interval: 10s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 512M

  # ── Backend (NestJS API) ────────────────────────────────────────────────────
  backend:
    image: BACKEND_IMAGE_PLACEHOLDER
    restart: unless-stopped
    environment:
      NODE_ENV:            production
      DATABASE_URL:        postgresql://${DB_USER:-tm_user}:${DB_PASSWORD}@postgres:5432/${DB_NAME:-tm_scheduler}
      JWT_SECRET:          ${JWT_SECRET}
      JWT_EXPIRES_IN:      ${JWT_EXPIRES_IN:-7d}
      ADMIN_USERNAME:      ${ADMIN_USERNAME:-admin}
      ADMIN_PASSWORD_HASH: ${ADMIN_PASSWORD_HASH}
      CORS_ORIGIN:         ${CORS_ORIGIN:-http://localhost}
    depends_on:
      postgres:
        condition: service_healthy
    deploy:
      resources:
        limits:
          cpus: '1'
          memory: 512M

  # ── Frontend (React / nginx) ────────────────────────────────────────────────
  frontend:
    image: FRONTEND_IMAGE_PLACEHOLDER
    restart: unless-stopped
    ports:
      - "${HTTP_PORT:-80}:80"
    depends_on:
      - backend
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 128M

  # ── pgAdmin (database UI) ───────────────────────────────────────────────────
  pgadmin:
    image: dpage/pgadmin4:latest
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL:              ${PGADMIN_EMAIL:-admin@example.com}
      PGADMIN_DEFAULT_PASSWORD:           ${PGADMIN_PASSWORD:-pgadmin}
      PGADMIN_CONFIG_SERVER_MODE:         'False'
      PGADMIN_CONFIG_MASTER_PASSWORD_REQUIRED: 'False'
    ports:
      - "${PGADMIN_PORT:-5050}:80"
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    depends_on:
      postgres:
        condition: service_healthy
    deploy:
      resources:
        limits:
          cpus: '0.5'
          memory: 256M

volumes:
  postgres_data:
  pgadmin_data:
